# ============================================================
# BTC Automated Financial System - Environment Example
# ============================================================
#
# Este arquivo é um modelo de configuração.
# Copie este arquivo para ".env" antes de rodar o projeto localmente.
#
# Comando:
# Copy-Item .env.example .env
#
# IMPORTANTE:
# - Nunca coloque chaves reais neste arquivo.
# - Nunca envie o arquivo .env para o Git.
# - O modo padrão deve ser "paper" e com trading real desativado.
# - Binance Futures será o venue principal desta fase.
# - Polymarket fica preservado para market data, paper/research e uso futuro.
# ============================================================


# ============================================================
# Application
# ============================================================

APP_NAME=btc-polymarket-bot
APP_ENV=development
LOG_LEVEL=INFO

# Modos possíveis:
# data     = somente coleta de dados
# paper    = simulação sem enviar ordens reais
# live     = execução real
# backtest = execução histórica para validação
TRADING_MODE=paper

# Segurança operacional
ENABLE_TRADING=false
ENABLE_PAPER_TRADING=true
ENABLE_BACKTEST=true


# ============================================================
# Venue Selection / Multi-Venue Architecture
# ============================================================

# Venue principal de execução nesta fase.
PRIMARY_TRADING_VENUE=binance_futures

# Venues auxiliares usados para dados, pesquisa, paper ou features.
SECONDARY_DATA_VENUES=polymarket,binance,free_onchain,sentiment

# Binance Futures será o foco operacional.
BINANCE_FUTURES_ENABLED=true
BINANCE_FUTURES_MARKET_DATA_ENABLED=true
BINANCE_FUTURES_PAPER_TRADING_ENABLED=true

# Live trading permanece bloqueado até risk/compliance/paper trading validarem tudo.
BINANCE_FUTURES_LIVE_TRADING_ALLOWED=false

# Polymarket permanece no sistema para dados, pesquisa, paper e uso futuro.
POLYMARKET_ENABLED=true
POLYMARKET_MARKET_DATA_ENABLED=true
POLYMARKET_PAPER_TRADING_ENABLED=true

# Polymarket live trading fica bloqueado por padrão no Brasil.
POLYMARKET_LIVE_TRADING_ALLOWED=false


# ============================================================
# Compliance / Geoblock / Jurisdiction
# ============================================================

APP_COUNTRY=BR
APP_JURISDICTION=Brazil

COMPLIANCE_MODE=strict

ENABLE_COMPLIANCE_CHECK=true
ENABLE_GEOLOCATION_CHECK=true
ENABLE_POLYMARKET_GEO_CHECK=true

REQUIRE_MANUAL_LEGAL_APPROVAL_FOR_LIVE=true
LEGAL_APPROVAL_CONFIRMED=false

COMPLIANCE_BLOCK_ON_UNKNOWN_JURISDICTION=true

# Países bloqueados para live trading na Polymarket nesta configuração.
POLYMARKET_RESTRICTED_COUNTRIES=BR

ALLOW_LIVE_TRADING_IN_RESTRICTED_REGION=false

POLYMARKET_BLOCK_REASON=Brazil prediction market restrictions / geoblock risk

COMPLIANCE_AUDIT_LOG_ENABLED=true
COMPLIANCE_AUDIT_LOG_FILE=logs/audit/compliance.jsonl


# ============================================================
# Polymarket APIs
# ============================================================

# Gamma API é usada para descoberta de mercados, eventos e metadados.
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com

# Data API poderá ser usada futuramente para trades, posições e histórico.
POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com

# CLOB API será usada para order book, preços e execução futura se permitido.
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# CLOB Market Data
POLYMARKET_CLOB_REQUEST_TIMEOUT_SECONDS=15
POLYMARKET_CLOB_BOOKS_BATCH_SIZE=50

# Token opcional para teste manual do CLOB.
POLYMARKET_CLOB_TEST_TOKEN_ID=

# WebSocket CLOB da Polymarket.
POLYMARKET_WS_MARKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_WS_USER_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

# URL padrão de WebSocket usada por compatibilidade geral do projeto.
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market


# ============================================================
# Polymarket WebSocket / Realtime Market Data
# ============================================================

POLYMARKET_WS_MARKET_ENABLED=true

# Deve permanecer false até existirem credenciais e compliance permitir.
POLYMARKET_WS_USER_ENABLED=false

# Token IDs usados para teste manual do market WebSocket.
POLYMARKET_WS_MARKET_ASSET_IDS=

# Condition IDs usados para filtrar o canal user.
POLYMARKET_WS_USER_MARKETS=

POLYMARKET_WS_PING_INTERVAL_SECONDS=10
POLYMARKET_WS_RECONNECT_INITIAL_SECONDS=2
POLYMARKET_WS_RECONNECT_MAX_SECONDS=60
POLYMARKET_WS_RUN_SECONDS=30

POLYMARKET_WS_ORDERBOOK_TOPIC=poly-orderbook
POLYMARKET_WS_USER_ORDERS_TOPIC=orders
POLYMARKET_WS_USER_FILLS_TOPIC=fills


# ============================================================
# Polymarket Gamma / Market Discovery
# ============================================================

POLYMARKET_GAMMA_BITCOIN_TAG=bitcoin
POLYMARKET_GAMMA_BITCOIN_TAG_ID=
POLYMARKET_GAMMA_MARKETS_LIMIT=100
POLYMARKET_GAMMA_MARKETS_MAX_PAGES=5
POLYMARKET_GAMMA_REQUEST_TIMEOUT_SECONDS=15


# ============================================================
# Binance Futures / Market Data
# ============================================================

PRIMARY_EXCHANGE=binance
SECONDARY_EXCHANGE=polymarket

BTC_SYMBOL=BTCUSDT

# Nunca coloque chaves reais no .env.example.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance USDⓈ-M Futures REST API.
BINANCE_FUTURES_REST_URL=https://fapi.binance.com

# Binance USDⓈ-M Futures WebSocket Market Streams.
BINANCE_FUTURES_WS_BASE_URL=wss://fstream.binance.com/market

# Mantido por compatibilidade geral do projeto.
BINANCE_REST_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com/market

# Símbolo principal de futuros BTC.
BINANCE_FUTURES_SYMBOL=BTCUSDT

# Streams oficiais de candles usados pelo sistema.
BINANCE_KLINE_INTERVALS=5m,15m,1h,1d

# Publicar somente candles fechados.
# true = publica apenas quando x=true no kline.
# false = publica atualizações parciais também.
BINANCE_PUBLISH_ONLY_CLOSED_KLINES=true

# Frequência para atualizar métricas REST complementares.
BINANCE_FUTURES_METRICS_REFRESH_SECONDS=30

# Tempo máximo para teste manual.
# 0 = roda indefinidamente.
BINANCE_WS_RUN_SECONDS=60

# Tópico Redpanda/Kafka para candles BTC.
BINANCE_CANDLES_TOPIC=btc-candles


# ============================================================
# Binance Futures / Trading Configuration
# ============================================================

# Configuração operacional padrão.
BINANCE_FUTURES_MARGIN_TYPE=ISOLATED
BINANCE_FUTURES_POSITION_MODE=ONE_WAY
BINANCE_FUTURES_LEVERAGE=30

# Ordem padrão.
BINANCE_FUTURES_ORDER_TYPE=LIMIT
BINANCE_FUTURES_ENABLE_LIMIT_ORDERS=true
BINANCE_FUTURES_ENABLE_MARKET_ORDERS=false

# Proteções para execução.
BINANCE_FUTURES_MAX_SLIPPAGE_PCT=0.001
BINANCE_FUTURES_MAX_SPREAD_PCT=0.002

# Configurações futuras de conta/execução.
BINANCE_FUTURES_RECV_WINDOW=5000
BINANCE_FUTURES_ORDER_TIMEOUT_SECONDS=30
BINANCE_FUTURES_CANCEL_STALE_ORDERS=true

# User Data Stream futuro.
BINANCE_FUTURES_USER_STREAM_ENABLED=false
BINANCE_FUTURES_USER_WS_RUN_SECONDS=0
BINANCE_FUTURES_LISTEN_KEY_KEEPALIVE_MINUTES=30


# ============================================================
# Binance Futures Paper Risk Profile
# ============================================================

# Estrutura alvo para paper trading.
BINANCE_FUTURES_PAPER_MARGIN_USD=20
BINANCE_FUTURES_PAPER_LEVERAGE=30
BINANCE_FUTURES_PAPER_NOTIONAL_USD=600

# Alvo de lucro líquido e controle bruto.
BINANCE_FUTURES_TARGET_NET_PROFIT_USD=2.00
BINANCE_FUTURES_GROSS_TAKE_PROFIT_USD=2.10
BINANCE_FUTURES_GROSS_STOP_LOSS_USD=1.05

# Taxas estimadas.
# Ajustar conforme conta, VIP level, maker/taker e tipo de ordem.
BINANCE_FUTURES_ESTIMATED_ENTRY_FEE_USD=0.05
BINANCE_FUTURES_ESTIMATED_EXIT_FEE_USD=0.05

# Relação risco/retorno alvo.
BINANCE_FUTURES_TARGET_RISK_REWARD_RATIO=2.0

# Proteções adicionais de paper/risk.
BINANCE_FUTURES_MAX_POSITION_NOTIONAL_USD=600
BINANCE_FUTURES_MAX_DAILY_LOSS_USD=5
BINANCE_FUTURES_MAX_CONSECUTIVE_LOSSES=3


# ============================================================
# Timeframes
# ============================================================

ENABLE_TF_5M=true
ENABLE_TF_15M=true
ENABLE_TF_1H=true
ENABLE_TF_1D=true

DEFAULT_TIMEFRAMES=5m,15m,1h,1d


# ============================================================
# Strategy / Candle Buffers
# ============================================================

# Timeframes usados pela strategy Binance Futures.
STRATEGY_TIMEFRAMES=5m,15m,1h,1d

# Quantidade máxima de candles mantidos por timeframe.
STRATEGY_CANDLE_BUFFER_SIZE=500

# Mínimo necessário para indicadores longos como EMA200.
STRATEGY_MIN_CANDLES_FOR_EMA200=200

# Venue principal da strategy nesta fase.
STRATEGY_PRIMARY_VENUE=binance_futures

# Símbolo principal da strategy.
STRATEGY_SYMBOL=BTCUSDT


# ============================================================
# On-chain Data Providers
# ============================================================

# Provider principal gratuito de dados on-chain.
ONCHAIN_PROVIDER=free


# ============================================================
# Free On-chain Providers
# ============================================================

MEMPOOL_BASE_URL=https://mempool.space/api

# DefiLlama geral e stablecoins.
DEFILLAMA_BASE_URL=https://api.llama.fi
DEFILLAMA_STABLECOINS_BASE_URL=https://stablecoins.llama.fi

FREE_ONCHAIN_STABLECOINS=USDT,USDC,DAI

FREE_ONCHAIN_PUBLISH_TO_KAFKA=true
FREE_ONCHAIN_TOPIC=onchain-events
FREE_ONCHAIN_RUN_SECONDS=0
FREE_ONCHAIN_TIMEOUT_SECONDS=20
FREE_ONCHAIN_INTERVAL=snapshot

# Providers pagos ficam desativados nesta fase.
GLASSNODE_API_KEY=
GLASSNODE_BASE_URL=

CRYPTOQUANT_API_KEY=
CRYPTOQUANT_BASE_URL=

ARKHAM_API_KEY=
ARKHAM_BASE_URL=

WHALE_ALERT_API_KEY=
WHALE_ALERT_BASE_URL=

# ============================================================
# On-chain Engine / Strategy Scoring
# ============================================================

ONCHAIN_ENGINE_ENABLED=true

# Fonte principal atual.
ONCHAIN_ENGINE_PROVIDER=free_onchain

# Timeframes e pesos.
ONCHAIN_WEIGHT_5M=0.05
ONCHAIN_WEIGHT_15M=0.10
ONCHAIN_WEIGHT_1H=0.25
ONCHAIN_WEIGHT_1D=0.40

# Pesos por tipo de evento gratuito.
ONCHAIN_MEMPOOL_FEES_WEIGHT=0.35
ONCHAIN_MEMPOOL_STATS_WEIGHT=0.25
ONCHAIN_STABLECOIN_SUPPLY_WEIGHT=0.40

# Pesos para métricas premium futuras, caso existam.
ONCHAIN_WHALE_INFLOW_WEIGHT=0.35
ONCHAIN_WHALE_OUTFLOW_WEIGHT=0.35
ONCHAIN_STABLECOIN_INFLOW_WEIGHT=0.30
ONCHAIN_MINER_OUTFLOW_WEIGHT=0.25
ONCHAIN_EXCHANGE_INFLOW_WEIGHT=0.30
ONCHAIN_EXCHANGE_OUTFLOW_WEIGHT=0.30

# Tópico de entrada.
ONCHAIN_ENGINE_INPUT_TOPIC=onchain-events

# ============================================================
# Sentiment Data Providers
# ============================================================

SENTIMENT_PROVIDER=rss

SENTIMENT_PUBLISH_TO_KAFKA=true
SENTIMENT_TOPIC=sentiment-events

SENTIMENT_RUN_SECONDS=0
SENTIMENT_TIMEOUT_SECONDS=20
SENTIMENT_MAX_ITEMS=50
SENTIMENT_INTERVAL=snapshot

SENTIMENT_RSS_FEEDS=https://cointelegraph.com/rss,https://decrypt.co/feed

SENTIMENT_KEYWORDS=ETF,SEC,CPI,Fed,hack,liquidation,lawsuit,approval,ban

CRYPTOCOMPARE_API_KEY=
CRYPTOCOMPARE_NEWS_BASE_URL=https://min-api.cryptocompare.com
CRYPTOCOMPARE_NEWS_PATH=/data/v2/news/

# ============================================================
# Sentiment Engine / Strategy Scoring
# ============================================================

SENTIMENT_ENGINE_ENABLED=true

# Fonte principal atual.
SENTIMENT_ENGINE_PROVIDER=rss

# Timeframes e pesos.
# Sentimento tem peso baixo em scalping curto e maior em timeframes longos.
SENTIMENT_WEIGHT_5M=0.03
SENTIMENT_WEIGHT_15M=0.05
SENTIMENT_WEIGHT_1H=0.10
SENTIMENT_WEIGHT_1D=0.20

# Janela de suavização para reduzir ruído.
SENTIMENT_MOVING_AVERAGE_WINDOW_MINUTES=30

# Volume de menções usado como referência para amplificador.
SENTIMENT_VOLUME_BASELINE=10

# Multiplicador máximo aplicado quando há spike de menções.
# Amplifica força do sinal, não muda direção.
SENTIMENT_MAX_VOLUME_AMPLIFIER=1.50

# Keywords críticas usadas para auditoria/contexto.
SENTIMENT_RISK_KEYWORDS=hack,liquidation,lawsuit,ban,exploit,crash
SENTIMENT_BULLISH_KEYWORDS=approval,approved,rally,bullish,inflow,adoption,rate cut

# Tópico de entrada.
SENTIMENT_ENGINE_INPUT_TOPIC=sentiment-events

# ============================================================
# Database / TimescaleDB
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=btc_polymarket_bot
POSTGRES_USER=btc_user
POSTGRES_PASSWORD=btc_password_dev

DATABASE_URL=postgresql://btc_user:btc_password_dev@localhost:5432/btc_polymarket_bot

TIMESCALE_ENABLED=true
TIMESCALE_SCHEMA=market_data

BTC_CANDLES_RETENTION_DAYS=730
BINANCE_ORDERBOOK_RETENTION_DAYS=90
POLY_ORDERBOOK_RETENTION_DAYS=90
FEATURES_STORE_RETENTION_DAYS=730
SIGNALS_RETENTION_DAYS=730
PAPER_TRADES_RETENTION_DAYS=730

CLICKHOUSE_ENABLED=false
CLICKHOUSE_URL=


# ============================================================
# Redis / Cache / Streams
# ============================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis_password_dev

REDIS_URL=redis://:redis_password_dev@localhost:6379/0

REDIS_KEY_PREFIX=btc_poly_bot
REDIS_KEY_ENV=dev

REDIS_CANDLE_TTL_SECONDS=900
REDIS_ORDERBOOK_TTL_SECONDS=10
REDIS_FEATURES_TTL_SECONDS=300
REDIS_OPEN_ORDERS_TTL_SECONDS=86400
REDIS_CIRCUIT_BREAKER_TTL_SECONDS=3600
REDIS_PAPER_POSITIONS_TTL_SECONDS=86400

STREAM_ENGINE=redpanda

KAFKA_BROKERS=
REDPANDA_BROKERS=


# ============================================================
# Messaging / Event Streaming
# ============================================================

MESSAGE_BROKER=redpanda

KAFKA_BOOTSTRAP_SERVERS=localhost:19092
REDPANDA_BOOTSTRAP_SERVERS=localhost:19092

KAFKA_TOPIC_PARTITIONS=1
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_TOPIC_RETENTION_MS=604800000

# Tópicos oficiais do projeto.
TOPIC_BTC_CANDLES=btc-candles
TOPIC_BINANCE_ORDERBOOK=binance-orderbook
TOPIC_BINANCE_ACCOUNT_EVENTS=binance-account-events
TOPIC_POLY_ORDERBOOK=poly-orderbook
TOPIC_POLY_TRADES=poly-trades
TOPIC_ONCHAIN_EVENTS=onchain-events
TOPIC_SENTIMENT_EVENTS=sentiment-events
TOPIC_NORMALIZED_EVENTS=normalized-events
TOPIC_FEATURES=features
TOPIC_SIGNALS=signals
TOPIC_ORDERS=orders
TOPIC_FILLS=fills
TOPIC_PAPER_TRADES=paper-trades
TOPIC_RISK_EVENTS=risk-events
TOPIC_COMPLIANCE_EVENTS=compliance-events

# Consumer groups oficiais.
CONSUMER_GROUP_CANDLE_STORE=candle-store
CONSUMER_GROUP_TECHNICAL_ENGINE=technical-engine
CONSUMER_GROUP_ORDERBOOK_ENGINE=orderbook-engine
CONSUMER_GROUP_ONCHAIN_ENGINE=onchain-engine
CONSUMER_GROUP_SENTIMENT_ENGINE=sentiment-engine
CONSUMER_GROUP_FEATURE_STORE=feature-store
CONSUMER_GROUP_SIGNAL_ENGINE=signal-engine
CONSUMER_GROUP_RISK_MANAGER=risk-manager
CONSUMER_GROUP_EXECUTION=execution-engine
CONSUMER_GROUP_MONITORING=monitoring


# ============================================================
# Data Stores / Candle Store
# ============================================================

CANDLE_STORE_ENABLED=true
CANDLE_STORE_TOPIC=btc-candles
CANDLE_STORE_CONSUMER_GROUP=candle-store
CANDLE_STORE_REDIS_TTL_SECONDS=900
CANDLE_STORE_WRITE_REDIS=true
CANDLE_STORE_WRITE_TIMESCALE=false
CANDLE_STORE_RUN_SECONDS=60


# ============================================================
# Data Normalization
# ============================================================

NORMALIZER_ENABLED=true
NORMALIZER_TIMEZONE=UTC

NORMALIZER_FORWARD_FILL_FIELDS=funding_rate,open_interest,mark_price,index_price,fee_pressure_score,mempool_congestion_score,stablecoin_liquidity_score,sentiment_score

NORMALIZER_FORWARD_FILL_MAX_AGE_SECONDS=3600

NORMALIZER_INPUT_TOPICS=btc-candles,binance-orderbook,poly-orderbook,onchain-events,sentiment-events
NORMALIZER_OUTPUT_TOPIC=normalized-events


# ============================================================
# Data Lake / MinIO / S3
# ============================================================

DATA_LAKE_BACKEND=minio

MINIO_ENDPOINT=localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false

DATA_LAKE_BUCKET=btc-polymarket-datalake

DATA_LAKE_RAW_BTC_PREFIX=raw/btc
DATA_LAKE_RAW_BINANCE_PREFIX=raw/binance
DATA_LAKE_RAW_POLYMARKET_PREFIX=raw/polymarket
DATA_LAKE_RAW_ONCHAIN_PREFIX=raw/onchain
DATA_LAKE_RAW_SENTIMENT_PREFIX=raw/sentiment
DATA_LAKE_FEATURES_PREFIX=features
DATA_LAKE_MODELS_PREFIX=models

DATA_LAKE_FILE_FORMAT=parquet


# ============================================================
# Risk Management
# ============================================================

MAX_DAILY_LOSS_PCT=0.03
MAX_TRADE_RISK_PCT=0.005
MAX_MARKET_EXPOSURE_PCT=0.02
MAX_TOTAL_BTC_DIRECTIONAL_EXPOSURE_PCT=0.10

MAX_EXPOSURE_5M=0.02
MAX_EXPOSURE_15M=0.04
MAX_EXPOSURE_1H=0.06
MAX_EXPOSURE_1D=0.08

ENABLE_KILL_SWITCH=true
MAX_API_FAILURES=5
MAX_WS_DISCONNECTS=3

MAX_PRICE_DIVERGENCE_PCT=0.005

# Binance Futures specific risk.
BINANCE_FUTURES_MAX_LEVERAGE=30
BINANCE_FUTURES_MAX_MARGIN_USD=20
BINANCE_FUTURES_MAX_NOTIONAL_USD=600
BINANCE_FUTURES_MAX_DAILY_LOSS_USD=5
BINANCE_FUTURES_MAX_TRADE_LOSS_USD=1.05
BINANCE_FUTURES_MAX_OPEN_POSITIONS=1
BINANCE_FUTURES_MAX_OPEN_ORDERS=3

# Dados antigos bloqueiam decisão.
MAX_CANDLE_STALENESS_SECONDS=120
MAX_ORDERBOOK_STALENESS_SECONDS=10
MAX_FEATURE_STALENESS_SECONDS=300

# ============================================================
# Binance Futures Risk Manager
# ============================================================

RISK_MANAGER_ENABLED=true
RISK_PRIMARY_VENUE=binance_futures
RISK_SYMBOL=BTCUSDT

RISK_MARGIN_USD=20
RISK_LEVERAGE=30
RISK_NOTIONAL_USD=600

RISK_GROSS_TAKE_PROFIT_USD=2.10
RISK_GROSS_STOP_LOSS_USD=1.05

RISK_ESTIMATED_ENTRY_FEE_USD=0.05
RISK_ESTIMATED_EXIT_FEE_USD=0.05

RISK_MAX_LEVERAGE=30
RISK_MAX_MARGIN_USD=20
RISK_MAX_NOTIONAL_USD=600
RISK_MAX_DAILY_LOSS_USD=5
RISK_MAX_TRADE_LOSS_USD=1.05
RISK_MAX_CONSECUTIVE_LOSSES=3
RISK_MAX_OPEN_POSITIONS=1
RISK_MAX_OPEN_ORDERS=3

RISK_MAX_SPREAD_PCT=0.002
RISK_MIN_LIQUIDITY_USD=50000
RISK_MIN_CONFIDENCE=0.65

RISK_ALLOW_LIVE_TRADING=false
RISK_ALLOW_PAPER_TRADING=true

# ============================================================
# Risk Approval / Binance Futures
# ============================================================

RISK_APPROVAL_ENABLED=true

# Bankroll usada para limites percentuais.
RISK_BANKROLL_USD=2000

# Limite de risco por trade.
# O risco real deve ser calculado pelo stop + fees.
RISK_MAX_TRADE_RISK_PCT=0.01
RISK_RECOMMENDED_MIN_TRADE_RISK_PCT=0.0025

# Perda diária máxima.
RISK_MAX_DAILY_LOSS_PCT=0.03

# Exposição máxima por mercado/símbolo.
RISK_MAX_MARKET_EXPOSURE_PCT=0.05

# Exposição direcional total em BTC.
RISK_MAX_BTC_DIRECTIONAL_EXPOSURE_PCT=0.10

# Exposição por timeframe.
RISK_MAX_EXPOSURE_5M=0.02
RISK_MAX_EXPOSURE_15M=0.04
RISK_MAX_EXPOSURE_1H=0.06
RISK_MAX_EXPOSURE_1D=0.08

# Edge mínimo por timeframe.
RISK_MIN_EDGE_5M=0.035
RISK_MIN_EDGE_15M=0.025
RISK_MIN_EDGE_1H=0.020
RISK_MIN_EDGE_1D=0.015

# Edge ainda opcional até a integração completa com predict.py.
# Quando o pipeline estiver 100% integrado com modelo, mudar para true.
RISK_REQUIRE_EDGE=false

RISK_MIN_CONFIDENCE=0.65

# Limites mínimos de liquidez por timeframe.
RISK_MIN_LIQUIDITY_USD_5M=50000
RISK_MIN_LIQUIDITY_USD_15M=75000
RISK_MIN_LIQUIDITY_USD_1H=100000
RISK_MIN_LIQUIDITY_USD_1D=150000


# ============================================================
# Risk Exposure Store
# ============================================================

EXPOSURE_STORE_ENABLED=true
EXPOSURE_STORE_BACKEND=memory
EXPOSURE_REDIS_KEY=btc_poly_bot:dev:risk:exposure
EXPOSURE_REDIS_TTL_SECONDS=86400


# ============================================================
# Fractional Kelly Sizing
# ============================================================

SIZING_ENABLED=true

# Kelly fracionado conservador.
KELLY_REDUCTION_FACTOR=0.10
KELLY_MAX_REDUCTION_FACTOR=0.25

# Hard cap: 0.5% da banca.
SIZING_MAX_BANKROLL_PCT=0.005

# Não consumir mais que 5% da liquidez visível.
SIZING_MAX_MARKET_LIQUIDITY_PCT=0.05

# Tamanho mínimo para paper trade.
SIZING_MIN_POSITION_USD=1.00


# ============================================================
# Kill Switch / Circuit Breaker
# ============================================================

KILL_SWITCH_ENABLED=true

KILL_SWITCH_MAX_WS_DISCONNECTED_SECONDS=30
KILL_SWITCH_MAX_BTC_PRICE_DIVERGENCE_PCT=0.005
KILL_SWITCH_MAX_SPREAD_PCT=0.002
KILL_SWITCH_MAX_SLIPPAGE_PCT=0.001
KILL_SWITCH_MAX_API_ERRORS=5
KILL_SWITCH_CANCEL_OPEN_ORDERS=true

# Se o modelo detectar OOD, o kill switch pode bloquear novas entradas.
KILL_SWITCH_TRIGGER_ON_MODEL_OOD=true

# ============================================================
# Accounting / Positions
# ============================================================

POSITIONS_ENABLED=true
POSITIONS_PRIMARY_VENUE=binance_futures
POSITIONS_SYMBOL=BTCUSDT


# ============================================================
# Paper Executor
# ============================================================

PAPER_EXECUTOR_ENABLED=true
PAPER_EXECUTOR_PRIMARY_VENUE=binance_futures

PAPER_EXECUTOR_SLIPPAGE_PCT=0.0005
PAPER_EXECUTOR_ENTRY_FEE_USD=0.05

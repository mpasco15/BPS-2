# ============================================================

OPS_CHECK_ENABLED=true
OPS_OUTPUT_DIR=artifacts/ops

# Jurisdição do operador. Use apenas como registro operacional.
OPS_OPERATOR_COUNTRY=BR
OPS_REQUIRE_LEGAL_REVIEW_BEFORE_LIVE=true
OPS_LEGAL_REVIEW_APPROVED=false

# Pré-requisitos antes de qualquer live.
OPS_REQUIRE_PAPER_TRADING=true
OPS_REQUIRE_BACKTEST_POSITIVE=true
OPS_REQUIRE_CALIBRATION_VALID=true
OPS_REQUIRE_KILL_SWITCH_TESTED=true
OPS_REQUIRE_ALERTS_ENABLED=true
OPS_REQUIRE_OBSERVABILITY_ENABLED=true

# Segurança.
OPS_REQUIRE_ENV_GITIGNORED=true
OPS_REQUIRE_ARTIFACTS_GITIGNORED=true
OPS_REQUIRE_NO_SECRETS_IN_EXAMPLE=true
OPS_REQUIRE_LIVE_TRADING_DISABLED_BY_DEFAULT=true

# ============================================================
# Emergency Shutdown / Safe Mode
# ============================================================

EMERGENCY_SHUTDOWN_ENABLED=true
EMERGENCY_SHUTDOWN_OUTPUT_DIR=artifacts/ops
EMERGENCY_SHUTDOWN_STATE_FILE=artifacts/ops/emergency_shutdown_state.json

# Em true, não envia cancelamento real; apenas simula.
EMERGENCY_SHUTDOWN_DRY_RUN=true

# Bloqueia novas entradas quando safe mode estiver ativo.
EMERGENCY_SHUTDOWN_BLOCK_NEW_ENTRIES=true

# Cancela ordens abertas quando acionado.
EMERGENCY_SHUTDOWN_CANCEL_OPEN_ORDERS=true

# Motivo padrão.
EMERGENCY_SHUTDOWN_DEFAULT_REASON=manual_operator_request

# ============================================================

# ============================================================

FEATURE_STORE_ENABLED=true

# Escrita de snapshots.
FEATURE_STORE_WRITE_TIMESCALE=true
FEATURE_STORE_WRITE_REDIS=true

# Tópico futuro de snapshots de features.
FEATURE_STORE_TOPIC=features
FEATURE_STORE_CONSUMER_GROUP=feature-store


# 1d
TECH_1D_EMA_FAST=50
TECH_1D_EMA_SLOW=200
TECH_1D_RSI_PERIOD=14
TECH_1D_REALIZED_VOL_WINDOW=30

# ============================================================
# Orderbook Engine / Binance Futures Microstructure
# ============================================================

ORDERBOOK_ENGINE_ENABLED=true

# Venue e símbolo principal.
ORDERBOOK_PRIMARY_VENUE=binance_futures
ORDERBOOK_SYMBOL=BTCUSDT

# Número de níveis usados na análise.
# Binance partial depth suporta 5, 10 ou 20 níveis.
ORDERBOOK_DEPTH_LEVELS=5

# Spread máximo permitido para considerar o book operável.
# 0.002 = 0.20%
ORDERBOOK_MAX_SPREAD_PCT=0.002

# Profundidade mínima em USD/notional em cada lado do book.
ORDERBOOK_MIN_DEPTH_USD=50000

# Gap máximo tolerado entre níveis consecutivos.
# 0.001 = 0.10%
ORDERBOOK_MAX_LIQUIDITY_GAP_PCT=0.001

# Pesos do microstructure_score.
ORDERBOOK_WEIGHT_IMBALANCE=0.55
ORDERBOOK_WEIGHT_WEIGHTED_MID=0.25
ORDERBOOK_WEIGHT_DEPTH_RATIO=0.20

# Tópico futuro para orderbook Binance.
BINANCE_ORDERBOOK_TOPIC=binance-orderbook

# ============================================================
# Binance Futures Orderbook WebSocket
# ============================================================

BINANCE_FUTURES_ORDERBOOK_WS_ENABLED=true

# Endpoint público de alta frequência para depth streams.
BINANCE_FUTURES_ORDERBOOK_WS_BASE_URL=wss://fstream.binance.com/public

# Símbolo e profundidade.
BINANCE_FUTURES_ORDERBOOK_SYMBOL=BTCUSDT
BINANCE_FUTURES_ORDERBOOK_DEPTH_LEVELS=5

# Velocidade do stream.
# Valores aceitos pela Binance: 100ms, 500ms ou vazio/250ms padrão.
BINANCE_FUTURES_ORDERBOOK_UPDATE_SPEED=100ms

# Tempo máximo para teste manual.
# 0 = roda indefinidamente.
BINANCE_FUTURES_ORDERBOOK_RUN_SECONDS=60

# Reconexão automática.
BINANCE_FUTURES_ORDERBOOK_RECONNECT_INITIAL_SECONDS=2
BINANCE_FUTURES_ORDERBOOK_RECONNECT_MAX_SECONDS=60

# Publicação no Redpanda/Kafka.
BINANCE_FUTURES_ORDERBOOK_PUBLISH_TO_KAFKA=true
BINANCE_ORDERBOOK_TOPIC=binance-orderbook


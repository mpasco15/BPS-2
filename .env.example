CANCEL_ORDER_CANCEL_ON_KILL_SWITCH=true

# ============================================================
# Signal Engine / Signal Rules
# ============================================================

SIGNAL_ENGINE_ENABLED=true

# Venue principal da geração de sinais.
SIGNAL_PRIMARY_VENUE=binance_futures
SIGNAL_SYMBOL=BTCUSDT

# Direção permitida nesta fase.
# both = long e short
# long_only = apenas compra
# short_only = apenas venda
SIGNAL_ALLOWED_DIRECTIONS=both

# Score mínimo combinado para gerar sinal por timeframe.
MIN_COMBINED_SCORE_5M=0.35
MIN_COMBINED_SCORE_15M=0.30
MIN_COMBINED_SCORE_1H=0.25
MIN_COMBINED_SCORE_1D=0.20

# Confiança mínima para o sinal seguir para o risk manager.
MIN_CONFIDENCE=0.65

# Filtros de qualidade de mercado.
SIGNAL_REQUIRE_TRADEABLE_BOOK=true
SIGNAL_MAX_SPREAD_PCT=0.002
SIGNAL_MIN_LIQUIDITY_USD=50000

# Dados antigos bloqueiam sinal.
SIGNAL_MAX_FEATURE_STALENESS_SECONDS=300
SIGNAL_MAX_ORDERBOOK_STALENESS_SECONDS=10

# Bloqueia sinais quando microestrutura contradiz fortemente a direção.
SIGNAL_REQUIRE_MICROSTRUCTURE_ALIGNMENT=true
SIGNAL_MICROSTRUCTURE_CONTRADICTION_THRESHOLD=0.25

# Tópico futuro de saída dos sinais.
SIGNAL_OUTPUT_TOPIC=signals


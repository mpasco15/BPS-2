# ============================================================

ORDER_TYPE=limit

ENABLE_LIMIT_ORDERS=true
ENABLE_MARKET_ORDERS=false

MAX_SLIPPAGE_PCT=0.001
MAX_SPREAD_PCT=0.002

MIN_LIQUIDITY_USD=1000


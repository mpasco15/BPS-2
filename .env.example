# live    = permitido somente com BINANCE_ALLOW_LIVE_TRADING=true
BINANCE_EXECUTION_MODE=paper

BINANCE_ALLOW_LIVE_TRADING=false

BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=

BINANCE_FUTURES_REST_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_TESTNET_REST_BASE_URL=https://demo-fapi.binance.com

BINANCE_FUTURES_RECV_WINDOW=5000
BINANCE_FUTURES_REQUEST_TIMEOUT_SECONDS=15

BINANCE_EXECUTION_SYMBOLS=BTCUSDT
BINANCE_EXECUTION_TIMEFRAMES=5m,15m,1h,1d

BINANCE_DEFAULT_ORDER_TYPE=LIMIT
BINANCE_DEFAULT_TIME_IN_FORCE=GTC

# No Binance, GTD exige goodTillDate > agora + 600s.
# Para expiração curta, usaremos cancel_order.py por max_order_age.
BINANCE_ORDER_MAX_AGE_SECONDS=60

BINANCE_ENTRY_SLIPPAGE_MAX_PCT=0.0005
BINANCE_REDUCE_ONLY=false

BINANCE_CLIENT_ORDER_ID_PREFIX=btc_poly_bot


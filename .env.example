# ============================================================

ORDER_ROUTER_ENABLED=true

# Em paper, a ordem é apenas simulada pelo client.
# Em testnet, pode enviar para demo-fapi.
# Em live, continua bloqueado salvo BINANCE_ALLOW_LIVE_TRADING=true.
ORDER_ROUTER_SUBMIT_ORDERS=true

# true = usa /fapi/v1/order/test para validar payload sem entrar no book.
# false = usa /fapi/v1/order, mas em paper continua simulado.
ORDER_ROUTER_USE_TEST_ENDPOINT=false

ORDER_ROUTER_PUBLISH_TO_KAFKA=false
ORDER_ROUTER_ORDERS_TOPIC=orders

ORDER_ROUTER_STORE_BACKEND=memory
ORDER_ROUTER_REDIS_PREFIX=btc_poly_bot:dev:orders



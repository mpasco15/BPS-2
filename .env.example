# Safety: testnet order submission permanece bloqueado por padrão.
TESTNET_ORDER_GUARD_ENABLED=true
TESTNET_ORDER_GUARD_REQUIRE_TESTNET_READY=true
TESTNET_ORDER_GUARD_REQUIRE_SUBMISSION_FLAG=true

RETRAINING_MIN_NEW_SAMPLES=500
RETRAINING_MAX_ECE=0.15
RETRAINING_MAX_BRIER_SCORE=0.25
RETRAINING_MIN_PROFIT_FACTOR=1.10
RETRAINING_MIN_SHARPE=0.50
RETRAINING_MAX_DRAWDOWN_PCT=0.20

RETRAINING_REQUIRE_BACKTEST_POSITIVE=true
RETRAINING_REQUIRE_CALIBRATION_VALID=true
RETRAINING_REQUIRE_CANDIDATE_BEATS_CURRENT=true

# Segurança: nunca promover automaticamente por padrão.
RETRAINING_ALLOW_AUTO_PROMOTE=false


# ============================================================
# Weekly Audit
# ============================================================

WEEKLY_AUDIT_ENABLED=true
WEEKLY_AUDIT_OUTPUT_DIR=artifacts/ops

WEEKLY_AUDIT_MIN_FILL_RATE=0.60

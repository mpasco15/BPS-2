EXECUTION_ENABLE_PAPER=true
EXECUTION_ENABLE_LIVE=false

# Polymarket execution fica desativada para live.
POLYMARKET_EXECUTION_ENABLED=false
BINANCE_FUTURES_EXECUTION_ENABLED=true

# ============================================================

# ============================================================

RUNBOOK_ENABLED=true
RUNBOOK_OUTPUT_DIR=artifacts/ops

RUNBOOK_DEFAULT_STAGE=testnet

# Critérios mínimos antes de testnet/live.
RUNBOOK_MIN_PAPER_TRADING_DAYS=14
RUNBOOK_MIN_TESTNET_DAYS=14

RUNBOOK_MIN_PAPER_TRADES=50
RUNBOOK_MIN_TESTNET_TRADES=50

RUNBOOK_MIN_FILL_RATE=0.60
RUNBOOK_MIN_PROFIT_FACTOR=1.10
RUNBOOK_MIN_SHARPE=0.50

RUNBOOK_MAX_DRAWDOWN_PCT=0.20
RUNBOOK_MAX_ECE=0.15
RUNBOOK_MAX_BRIER_SCORE=0.25

RUNBOOK_REQUIRE_OPS_CHECK_PASS=true
RUNBOOK_REQUIRE_SECURITY_CHECK_PASS=true
RUNBOOK_REQUIRE_COMPLIANCE_CHECK_PASS=false

# Live só pode ser considerado se estiver explicitamente aprovado.
RUNBOOK_REQUIRE_LEGAL_REVIEW_FOR_LIVE=true
RUNBOOK_REQUIRE_TESTNET_FOR_LIVE=true

# ============================================================
# Model Retraining Protocol / Weekly Audit
# ============================================================

RETRAINING_PROTOCOL_ENABLED=true

# ============================================================
# BTC Polymarket Bot - Environment Example
# ============================================================
#
# Este arquivo é um modelo de configuração.
# Copie este arquivo para ".env" antes de rodar o projeto localmente.
#
# Comando:
# Copy-Item .env.example .env
#
# IMPORTANTE:
# - Nunca coloque chaves reais neste arquivo.
# - Nunca envie o arquivo .env para o Git.
# - O modo padrão deve ser "paper" e com trading real desativado.
# ============================================================


# ============================================================
# Application
# ============================================================

APP_NAME=btc-polymarket-bot
APP_ENV=development
LOG_LEVEL=INFO

# Modos possíveis:
# paper    = simulação sem enviar ordens reais
# live     = execução real
# backtest = execução histórica para validação
TRADING_MODE=paper

# Segurança operacional
ENABLE_TRADING=false
ENABLE_PAPER_TRADING=true
ENABLE_BACKTEST=true


# ============================================================
# Polymarket APIs
# ============================================================

# URLs públicas e privadas da infraestrutura Polymarket.
# Preencher com os endpoints oficiais usados na implementação.
POLYMARKET_GAMMA_BASE_URL=
POLYMARKET_DATA_BASE_URL=
POLYMARKET_CLOB_BASE_URL=
POLYMARKET_WS_URL=

# Credenciais de API.
# Não preencher neste arquivo.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Chaves e endereços usados para execução.
# Nunca colocar chave privada real no .env.example.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Compliance e restrições geográficas
ENABLE_GEO_CHECK=true
BLOCK_TRADING_IF_RESTRICTED=true


# ============================================================
# Bitcoin Market Data
# ============================================================

PRIMARY_EXCHANGE=binance
SECONDARY_EXCHANGE=coinbase

BTC_SYMBOL=BTCUSDT

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_REST_URL=
BINANCE_WS_URL=

# Coinbase
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_REST_URL=
COINBASE_WS_URL=


# ============================================================
# Timeframes
# ============================================================

ENABLE_TF_5M=true
ENABLE_TF_15M=true
ENABLE_TF_1H=true
ENABLE_TF_1D=true

DEFAULT_TIMEFRAMES=5m,15m,1h,1d


# ============================================================
# On-chain Data Providers
# ============================================================

GLASSNODE_API_KEY=
GLASSNODE_BASE_URL=

CRYPTOQUANT_API_KEY=
CRYPTOQUANT_BASE_URL=

ARKHAM_API_KEY=
ARKHAM_BASE_URL=

WHALE_ALERT_API_KEY=
WHALE_ALERT_BASE_URL=


# ============================================================
# Sentiment Data Providers
# ============================================================

# X / Twitter
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# News / Trends
NEWS_API_KEY=
GOOGLE_TRENDS_ENABLED=true


# ============================================================
# Database / TimescaleDB
# ============================================================

# Banco principal de séries temporais usado pelo projeto.
# Em desenvolvimento local, este banco será executado via Docker.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=btc_polymarket_bot
POSTGRES_USER=btc_user
POSTGRES_PASSWORD=btc_password_dev

# URL de conexão usada pelo Python/SQLAlchemy.
DATABASE_URL=postgresql://btc_user:btc_password_dev@localhost:5432/btc_polymarket_bot

# TimescaleDB
TIMESCALE_ENABLED=true
TIMESCALE_SCHEMA=market_data

# Retention policies
# Define por quanto tempo cada tipo de dado será mantido no banco.
BTC_CANDLES_RETENTION_DAYS=730
POLY_ORDERBOOK_RETENTION_DAYS=90
FEATURES_STORE_RETENTION_DAYS=730

# ClickHouse fica desativado nesta fase.
# Pode ser ativado futuramente como banco analítico separado.
CLICKHOUSE_ENABLED=false
CLICKHOUSE_URL=

# ============================================================
# Redis / Cache / Streams
# ============================================================

REDIS_URL=redis://localhost:6379/0

# Opções possíveis:
# redis
# kafka
# redpanda
STREAM_ENGINE=redis

KAFKA_BROKERS=
REDPANDA_BROKERS=


# ============================================================
# Data Lake
# ============================================================

DATA_LAKE_ENABLED=false

# S3
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# MinIO
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=


# ============================================================
# Risk Management
# ============================================================

# Limite máximo de perda diária.
# 0.03 = 3% da banca.
MAX_DAILY_LOSS_PCT=0.03

# Risco máximo por operação.
# 0.005 = 0.5% da banca.
MAX_TRADE_RISK_PCT=0.005

# Exposição máxima por mercado.
MAX_MARKET_EXPOSURE_PCT=0.02

# Exposição direcional total em mercados de BTC.
MAX_TOTAL_BTC_DIRECTIONAL_EXPOSURE_PCT=0.10

# Exposição máxima por timeframe.
MAX_EXPOSURE_5M=0.02
MAX_EXPOSURE_15M=0.04
MAX_EXPOSURE_1H=0.06
MAX_EXPOSURE_1D=0.08

# Kill switch
ENABLE_KILL_SWITCH=true
MAX_API_FAILURES=5
MAX_WS_DISCONNECTS=3

# Divergência máxima permitida entre fontes de preço.
# 0.005 = 0.5%
MAX_PRICE_DIVERGENCE_PCT=0.005


# ============================================================
# Execution
# ============================================================

# Tipo padrão de ordem.
# O projeto deve priorizar ordens limitadas.
ORDER_TYPE=limit

ENABLE_LIMIT_ORDERS=true
ENABLE_MARKET_ORDERS=false

# Slippage máximo permitido.
# 0.01 = 1%
MAX_SLIPPAGE_PCT=0.01

# Spread máximo permitido.
# 0.03 = 3%
MAX_SPREAD_PCT=0.03

# Liquidez mínima do mercado para permitir operação.
MIN_LIQUIDITY_USD=1000

# Tempo mínimo até o vencimento do mercado.
MIN_TIME_TO_EXPIRY_SECONDS=60

# Tempo máximo para manter uma ordem aberta sem preenchimento.
CANCEL_ORDER_AFTER_SECONDS=30


# ============================================================
# Signal Rules
# ============================================================

# Confiança mínima do sinal.
MIN_CONFIDENCE=0.65

# Edge mínimo por timeframe.
# Quanto menor o timeframe, maior o edge exigido.
MIN_EDGE_5M=0.035
MIN_EDGE_15M=0.030
MIN_EDGE_1H=0.020
MIN_EDGE_1D=0.015


# ============================================================
# Model Settings
# ============================================================

MODEL_NAME=btc_polymarket_model
MODEL_VERSION=dev

MODEL_PATH=artifacts/models/model.pkl
CALIBRATOR_PATH=artifacts/models/calibrator.pkl

ENABLE_MODEL_CALIBRATION=true
ENABLE_OUT_OF_DISTRIBUTION_CHECK=true

# Limite máximo de drift das features antes de bloquear sinais.
MAX_FEATURE_DRIFT_SCORE=0.20


# ============================================================
# Backtest
# ============================================================

BACKTEST_INITIAL_BANKROLL=10000

BACKTEST_INCLUDE_FEES=true
BACKTEST_INCLUDE_SLIPPAGE=true
BACKTEST_INCLUDE_PARTIAL_FILLS=true
BACKTEST_INCLUDE_LATENCY=true


# ============================================================
# Monitoring
# ============================================================

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

GRAFANA_ENABLED=true

ALERTS_ENABLED=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_WEBHOOK_URL=

# Email
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=


# ============================================================
# Logging / Audit
# ============================================================

LOG_TO_FILE=true
LOG_FILE_PATH=logs/app.log

AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=logs/audit.log
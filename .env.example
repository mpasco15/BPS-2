# ============================================================
# BTC Polymarket Bot - Environment Example
# ============================================================
#
# Este arquivo é um modelo de configuração.
# Copie este arquivo para ".env" antes de rodar o projeto localmente.
#
# Comando:
# Copy-Item .env.example .env
#
# IMPORTANTE:
# - Nunca coloque chaves reais neste arquivo.
# - Nunca envie o arquivo .env para o Git.
# - O modo padrão deve ser "paper" e com trading real desativado.
# ============================================================


# ============================================================
# Application
# ============================================================

APP_NAME=btc-polymarket-bot
APP_ENV=development
LOG_LEVEL=INFO

# Modos possíveis:
# paper    = simulação sem enviar ordens reais
# live     = execução real
# backtest = execução histórica para validação
TRADING_MODE=paper

# Segurança operacional
ENABLE_TRADING=false
ENABLE_PAPER_TRADING=true
ENABLE_BACKTEST=true

# ============================================================
# Polymarket APIs
# ============================================================

# Gamma API é usada para descoberta de mercados, eventos e metadados.
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com

# Data API poderá ser usada futuramente para trades, posições e histórico.
POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com

# CLOB API será usada futuramente para order book, preços e execução.
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# CLOB Market Data
POLYMARKET_CLOB_REQUEST_TIMEOUT_SECONDS=15
POLYMARKET_CLOB_BOOKS_BATCH_SIZE=50

# Token opcional para teste manual do CLOB.
# Pode ser preenchido temporariamente no .env local com um token YES/NO real.
POLYMARKET_CLOB_TEST_TOKEN_ID=

# WebSocket será configurado em etapa futura.
POLYMARKET_WS_URL=

# ============================================================
# Polymarket Gamma / Market Discovery
# ============================================================

# Palavra-chave usada para buscar mercados relacionados a Bitcoin.
POLYMARKET_GAMMA_BITCOIN_TAG=bitcoin

# Se descobrirmos futuramente o ID oficial da tag Bitcoin, colocamos aqui.
# Por enquanto deixamos vazio e usamos filtro por texto.
POLYMARKET_GAMMA_BITCOIN_TAG_ID=

# Quantidade de mercados buscados por página.
POLYMARKET_GAMMA_MARKETS_LIMIT=100

# Quantas páginas no máximo vamos buscar por execução.
POLYMARKET_GAMMA_MARKETS_MAX_PAGES=5

# Timeout da chamada HTTP.
POLYMARKET_GAMMA_REQUEST_TIMEOUT_SECONDS=15

# ============================================================
# Bitcoin Market Data
# ============================================================

PRIMARY_EXCHANGE=binance
SECONDARY_EXCHANGE=coinbase

BTC_SYMBOL=BTCUSDT

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_REST_URL=
BINANCE_WS_URL=

# Coinbase
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_REST_URL=
COINBASE_WS_URL=


# ============================================================
# Timeframes
# ============================================================

ENABLE_TF_5M=true
ENABLE_TF_15M=true
ENABLE_TF_1H=true
ENABLE_TF_1D=true

DEFAULT_TIMEFRAMES=5m,15m,1h,1d


# ============================================================
# On-chain Data Providers
# ============================================================

GLASSNODE_API_KEY=
GLASSNODE_BASE_URL=

CRYPTOQUANT_API_KEY=
CRYPTOQUANT_BASE_URL=

ARKHAM_API_KEY=
ARKHAM_BASE_URL=

WHALE_ALERT_API_KEY=
WHALE_ALERT_BASE_URL=


# ============================================================
# Sentiment Data Providers
# ============================================================

# X / Twitter
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# News / Trends
NEWS_API_KEY=
GOOGLE_TRENDS_ENABLED=true


# ============================================================
# Database / TimescaleDB
# ============================================================

# Banco principal de séries temporais usado pelo projeto.
# Em desenvolvimento local, este banco será executado via Docker.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=btc_polymarket_bot
POSTGRES_USER=btc_user
POSTGRES_PASSWORD=btc_password_dev

# URL de conexão usada pelo Python/SQLAlchemy.
DATABASE_URL=postgresql://btc_user:btc_password_dev@localhost:5432/btc_polymarket_bot

# TimescaleDB
TIMESCALE_ENABLED=true
TIMESCALE_SCHEMA=market_data

# Retention policies
# Define por quanto tempo cada tipo de dado será mantido no banco.
BTC_CANDLES_RETENTION_DAYS=730
POLY_ORDERBOOK_RETENTION_DAYS=90
FEATURES_STORE_RETENTION_DAYS=730

# ClickHouse fica desativado nesta fase.
# Pode ser ativado futuramente como banco analítico separado.
CLICKHOUSE_ENABLED=false
CLICKHOUSE_URL=

# ============================================================
# Redis / Cache / Streams
# ============================================================

# Redis será usado para cache rápido, estado operacional recente,
# order book em tempo real, features recentes, ordens abertas
# e circuit breakers.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis_password_dev

REDIS_URL=redis://:redis_password_dev@localhost:6379/0

# Prefixo oficial das chaves Redis do projeto.
REDIS_KEY_PREFIX=btc_poly_bot

# Ambiente usado dentro das chaves Redis.
# Exemplos:
# dev  = desenvolvimento local
# prod = produção real
REDIS_KEY_ENV=dev

# TTLs padrão em segundos.
REDIS_ORDERBOOK_TTL_SECONDS=10
REDIS_FEATURES_TTL_SECONDS=300
REDIS_OPEN_ORDERS_TTL_SECONDS=86400
REDIS_CIRCUIT_BREAKER_TTL_SECONDS=3600

# Opções possíveis:
# redis
# kafka
# redpanda
STREAM_ENGINE=redis

KAFKA_BROKERS=
REDPANDA_BROKERS=

# ============================================================
# Messaging / Event Streaming
# ============================================================

# Engine de mensageria usada pelo projeto.
# Opções:
# redpanda = recomendado para desenvolvimento local
# kafka    = opção futura para ambiente Kafka tradicional
MESSAGE_BROKER=redpanda

# Bootstrap servers usados pelos clientes Kafka/Redpanda.
# Dentro do Docker Compose, serviços usam redpanda:9092.
# Fora do Docker, o Python local usa localhost:19092.
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
REDPANDA_BOOTSTRAP_SERVERS=localhost:19092

# Configuração padrão dos tópicos.
KAFKA_TOPIC_PARTITIONS=1
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_TOPIC_RETENTION_MS=604800000

# Tópicos oficiais do projeto.
TOPIC_BTC_CANDLES=btc-candles
TOPIC_POLY_ORDERBOOK=poly-orderbook
TOPIC_POLY_TRADES=poly-trades
TOPIC_ONCHAIN_EVENTS=onchain-events
TOPIC_SENTIMENT_EVENTS=sentiment-events
TOPIC_SIGNALS=signals
TOPIC_ORDERS=orders
TOPIC_FILLS=fills

# Consumer groups oficiais.
CONSUMER_GROUP_TECHNICAL_ENGINE=technical-engine
CONSUMER_GROUP_ORDERBOOK_ENGINE=orderbook-engine
CONSUMER_GROUP_ONCHAIN_ENGINE=onchain-engine
CONSUMER_GROUP_SENTIMENT_ENGINE=sentiment-engine
CONSUMER_GROUP_RISK_MANAGER=risk-manager
CONSUMER_GROUP_EXECUTION=execution-engine
CONSUMER_GROUP_MONITORING=monitoring

# ============================================================
# Data Lake / MinIO / S3
# ============================================================

# Engine de data lake.
# Opções:
# minio = desenvolvimento local compatível com S3
# s3    = AWS S3 ou outro serviço S3-compatible em produção
DATA_LAKE_BACKEND=minio

# MinIO local
MINIO_ENDPOINT=localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false

# Bucket principal do projeto
DATA_LAKE_BUCKET=btc-polymarket-datalake

# Prefixos oficiais do data lake
DATA_LAKE_RAW_BTC_PREFIX=raw/btc
DATA_LAKE_RAW_POLYMARKET_PREFIX=raw/polymarket
DATA_LAKE_FEATURES_PREFIX=features
DATA_LAKE_MODELS_PREFIX=models

# Formato padrão dos arquivos analíticos
DATA_LAKE_FILE_FORMAT=parquet

# ============================================================
# Risk Management
# ============================================================

# Limite máximo de perda diária.
# 0.03 = 3% da banca.
MAX_DAILY_LOSS_PCT=0.03

# Risco máximo por operação.
# 0.005 = 0.5% da banca.
MAX_TRADE_RISK_PCT=0.005

# Exposição máxima por mercado.
MAX_MARKET_EXPOSURE_PCT=0.02

# Exposição direcional total em mercados de BTC.
MAX_TOTAL_BTC_DIRECTIONAL_EXPOSURE_PCT=0.10

# Exposição máxima por timeframe.
MAX_EXPOSURE_5M=0.02
MAX_EXPOSURE_15M=0.04
MAX_EXPOSURE_1H=0.06
MAX_EXPOSURE_1D=0.08

# Kill switch
ENABLE_KILL_SWITCH=true
MAX_API_FAILURES=5
MAX_WS_DISCONNECTS=3

# Divergência máxima permitida entre fontes de preço.
# 0.005 = 0.5%
MAX_PRICE_DIVERGENCE_PCT=0.005


# ============================================================
# Execution
# ============================================================

# Tipo padrão de ordem.
# O projeto deve priorizar ordens limitadas.
ORDER_TYPE=limit

ENABLE_LIMIT_ORDERS=true
ENABLE_MARKET_ORDERS=false

# Slippage máximo permitido.
# 0.01 = 1%
MAX_SLIPPAGE_PCT=0.01

# Spread máximo permitido.
# 0.03 = 3%
MAX_SPREAD_PCT=0.03

# Liquidez mínima do mercado para permitir operação.
MIN_LIQUIDITY_USD=1000

# Tempo mínimo até o vencimento do mercado.
MIN_TIME_TO_EXPIRY_SECONDS=60

# Tempo máximo para manter uma ordem aberta sem preenchimento.
CANCEL_ORDER_AFTER_SECONDS=30


# ============================================================
# Signal Rules
# ============================================================

# Confiança mínima do sinal.
MIN_CONFIDENCE=0.65

# Edge mínimo por timeframe.
# Quanto menor o timeframe, maior o edge exigido.
MIN_EDGE_5M=0.035
MIN_EDGE_15M=0.030
MIN_EDGE_1H=0.020
MIN_EDGE_1D=0.015


# ============================================================
# Model Settings
# ============================================================

MODEL_NAME=btc_polymarket_model
MODEL_VERSION=dev

MODEL_PATH=artifacts/models/model.pkl
CALIBRATOR_PATH=artifacts/models/calibrator.pkl

ENABLE_MODEL_CALIBRATION=true
ENABLE_OUT_OF_DISTRIBUTION_CHECK=true

# Limite máximo de drift das features antes de bloquear sinais.
MAX_FEATURE_DRIFT_SCORE=0.20


# ============================================================
# Backtest
# ============================================================

BACKTEST_INITIAL_BANKROLL=10000

BACKTEST_INCLUDE_FEES=true
BACKTEST_INCLUDE_SLIPPAGE=true
BACKTEST_INCLUDE_PARTIAL_FILLS=true
BACKTEST_INCLUDE_LATENCY=true

# ============================================================
# Monitoring / Prometheus / Grafana
# ============================================================

# Prometheus será usado para coletar e armazenar métricas.
PROMETHEUS_PORT=9090

# Grafana será usado para visualizar dashboards.
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_dev_password

# Porta futura onde a aplicação Python irá expor métricas.
APP_METRICS_PORT=8001

# Redis Exporter expõe métricas do Redis para o Prometheus.
REDIS_EXPORTER_PORT=9121

# Redpanda expõe métricas na Admin API.
REDPANDA_METRICS_PORT=9644

# Intervalo padrão de coleta do Prometheus.
PROMETHEUS_SCRAPE_INTERVAL=15s

# ============================================================
# Logging / Loki / Grafana Alloy
# ============================================================

# Backend oficial de logs nesta fase.
# Opções futuras:
# loki
# opensearch
LOGGING_BACKEND=loki

# Porta HTTP do Loki.
LOKI_PORT=3100

# Porta HTTP/debug do Grafana Alloy.
ALLOY_PORT=12345

# Ambiente usado nos labels dos logs.
LOG_ENV=dev

# Nome lógico do serviço nos logs.
LOG_SERVICE_NAME=btc-polymarket-bot

# Diretórios locais de logs.
LOG_DIR=logs
APP_LOG_DIR=logs/app
AUDIT_LOG_DIR=logs/audit

# Arquivos principais de log.
APP_LOG_FILE=logs/app/app.log
AUDIT_DECISIONS_LOG_FILE=logs/audit/decisions.jsonl

# Logs gerais da aplicação.
LOG_TO_FILE=true
LOG_FILE_PATH=logs/app/app.log

# Logs de auditoria.
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=logs/audit/decisions.jsonl
AUDIT_LOG_FORMAT=jsonl

# Regra operacional:
# logs de auditoria devem ser adicionados, nunca editados.
AUDIT_APPEND_ONLY=true

# Retenção local do Loki em desenvolvimento.
# 168h = 7 dias.
LOKI_RETENTION_PERIOD=168h

# ============================================================
# Orchestration / Prefect
# ============================================================

ORCHESTRATOR=prefect

# URL local da API do Prefect.
# Quando rodarmos "prefect server start", a API ficará disponível localmente.
PREFECT_API_URL=http://127.0.0.1:4200/api

# UI local do Prefect.
PREFECT_UI_URL=http://127.0.0.1:4200

# Timezone usada para agendamentos.
ORCHESTRATION_TIMEZONE=America/Campo_Grande

# Schedules oficiais do projeto.
CANDLES_INGESTION_INTERVAL_SECONDS=60
ONCHAIN_UPDATE_CRON=*/15 * * * *
MODEL_RETRAIN_CRON=0 3 * * 0
DATA_CLEANUP_CRON=0 2 * * *